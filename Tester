function CallRemoteServer(remote, ...)
    if not remote then return false end
    local ok
    if remote:IsA("RemoteFunction") then
        ok = select(1, pcall(function(...)
            remote:InvokeServer(...)
        end, ...))
    elseif remote:IsA("RemoteEvent") then
        ok = select(1, pcall(function(...)
            remote:FireServer(...)
        end, ...))
    else
        ok = select(1, pcall(function(...)
            remote:InvokeServer(...)
        end, ...))
        if not ok then
            ok = select(1, pcall(function(...)
                remote:FireServer(...)
            end, ...))
        end
    end
    return ok
end

